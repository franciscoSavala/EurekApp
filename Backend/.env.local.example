# Copiá este archivo como .env.local y completá los valores reales.
# .env.local NO se commitea (está en .gitignore).

# OpenAI — https://platform.openai.com/api-keys
OPENAI_SECRET_KEY=sk-...

# JWT — cualquier string largo y aleatorio (mínimo 32 caracteres)
JWT_SIGN_KEY=cambia-esto-por-un-string-largo-y-random-local

# Mailtrap — https://mailtrap.io → SMTP Settings → API Key
MAILTRAP_KEY=tu-api-key-de-mailtrap

# AWS — IAM user con permisos de S3
AWS_ACCESS_KEY_ID=AKIA....
AWS_SECRET_ACCESS_KEY=tu-secret-key-de-aws
