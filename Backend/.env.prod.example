# ─── EurekApp — Variables de entorno para producción ─────────────────────────
# Copiá este archivo a .env.prod en la EC2 y completá con valores reales.
# NUNCA commitear .env.prod al repositorio.

# ── MySQL (Docker Compose) ────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=cambia-esto-root
MYSQL_DATABASE=eurekapp
MYSQL_USER=eurekapp
MYSQL_PASSWORD=cambia-esto-db

# ── Spring Boot datasource ────────────────────────────────────────────────────
# Mismos valores que MYSQL_USER y MYSQL_PASSWORD de arriba
DATABASE_URL=jdbc:mysql://127.0.0.1:3306/eurekapp
DATABASE_USER=eurekapp
DATABASE_PASS=cambia-esto-db

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_SECRET_KEY=sk-...

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generá un string random: openssl rand -base64 32
JWT_SIGN_KEY=cambia-esto-por-un-string-muy-largo-y-random

# ── Mailtrap SMTP ─────────────────────────────────────────────────────────────
MAILTRAP_KEY=tu-api-key-de-mailtrap

# ── AWS S3 (bucket: eurekapp-temp, región: sa-east-1) ─────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=tu-secret-key-de-aws
AWS_REGION=sa-east-1

# ── Pinecone (no se usa, necesario para evitar crash) ─────────────────────────
PINECONE_SECRET_KEY=unused
